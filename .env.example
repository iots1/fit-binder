# ──────────────────────────────────────────────────────────────
#  General
# ──────────────────────────────────────────────────────────────
NODE_ENV=dev
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────
#  Security
# ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# ──────────────────────────────────────────────────────────────
#  Databases (one per Bounded Context)
# ──────────────────────────────────────────────────────────────
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USERNAME=postgres
AUTH_DB_PASSWORD=postgres
AUTH_DB_NAME=fit_binder_auth

TRAINER_DB_HOST=localhost
TRAINER_DB_PORT=5432
TRAINER_DB_USERNAME=postgres
TRAINER_DB_PASSWORD=postgres
TRAINER_DB_NAME=fit_binder_trainer

TRAINEE_DB_HOST=localhost
TRAINEE_DB_PORT=5432
TRAINEE_DB_USERNAME=postgres
TRAINEE_DB_PASSWORD=postgres
TRAINEE_DB_NAME=fit_binder_trainee

PACKAGE_DB_HOST=localhost
PACKAGE_DB_PORT=5432
PACKAGE_DB_USERNAME=postgres
PACKAGE_DB_PASSWORD=postgres
PACKAGE_DB_NAME=fit_binder_package

APPOINTMENT_DB_HOST=localhost
APPOINTMENT_DB_PORT=5432
APPOINTMENT_DB_USERNAME=postgres
APPOINTMENT_DB_PASSWORD=postgres
APPOINTMENT_DB_NAME=fit_binder_appointment

# ──────────────────────────────────────────────────────────────
#  Services (HTTP + TCP microservice ports)
# ──────────────────────────────────────────────────────────────
AUTH_PREFIX_NAME=auth
AUTH_PREFIX_VERSION=v1
AUTH_MODULE_HTTP_PORT=3001
AUTH_MODULE_MICROSERVICE_HOST=localhost
AUTH_MODULE_MICROSERVICE_PORT=4001

TRAINER_PREFIX_NAME=trainer
TRAINER_PREFIX_VERSION=v1
TRAINER_BC_MODULE_HTTP_PORT=3002
TRAINER_BC_MODULE_MICROSERVICE_HOST=localhost
TRAINER_BC_MODULE_MICROSERVICE_PORT=4002

TRAINEE_PREFIX_NAME=trainee
TRAINEE_PREFIX_VERSION=v1
TRAINEE_BC_MODULE_HTTP_PORT=3003
TRAINEE_BC_MODULE_MICROSERVICE_HOST=localhost
TRAINEE_BC_MODULE_MICROSERVICE_PORT=4003

PACKAGE_PREFIX_NAME=package
PACKAGE_PREFIX_VERSION=v1
PACKAGE_BC_MODULE_HTTP_PORT=3004
PACKAGE_BC_MODULE_MICROSERVICE_HOST=localhost
PACKAGE_BC_MODULE_MICROSERVICE_PORT=4004

APPOINTMENT_PREFIX_NAME=appointment
APPOINTMENT_PREFIX_VERSION=v1
APPOINTMENT_BC_MODULE_HTTP_PORT=3005
APPOINTMENT_BC_MODULE_MICROSERVICE_HOST=localhost
APPOINTMENT_BC_MODULE_MICROSERVICE_PORT=4005
