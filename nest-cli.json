{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "packageManager": "pnpm",
  "sourceRoot": "apps/auth/src",
  "monorepo": true,
  "root": "apps/auth",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/auth/tsconfig.app.json",
    "webpackConfigPath": "webpack.config.js"
  },
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "trainer-bc": {
      "type": "application",
      "root": "apps/trainer-bc",
      "entryFile": "main",
      "sourceRoot": "apps/trainer-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/trainer-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "trainee-bc": {
      "type": "application",
      "root": "apps/trainee-bc",
      "entryFile": "main",
      "sourceRoot": "apps/trainee-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/trainee-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "package-bc": {
      "type": "application",
      "root": "apps/package-bc",
      "entryFile": "main",
      "sourceRoot": "apps/package-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/package-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "appointment-bc": {
      "type": "application",
      "root": "apps/appointment-bc",
      "entryFile": "main",
      "sourceRoot": "apps/appointment-bc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/appointment-bc/tsconfig.app.json",
        "webpackConfigPath": "webpack.config.js",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    }
  }
}
