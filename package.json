{
  "name": "fit-binder",
  "version": "0.0.1",
  "description": "FitBinder - Personal trainer & trainee management platform (NestJS microservices monorepo)",
  "author": "FitBinder Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "build:auth": "nest build auth",
    "build:trainer-bc": "nest build trainer-bc",
    "build:trainee-bc": "nest build trainee-bc",
    "build:package-bc": "nest build package-bc",
    "build:appointment-bc": "nest build appointment-bc",
    "build:all": "for app in auth trainer-bc trainee-bc package-bc appointment-bc; do echo \"Building $app...\" && nest build $app; done",
    "start:dev:auth": "nest start auth --watch | pino-pretty -c -t -l",
    "start:dev:trainer-bc": "nest start trainer-bc --watch | pino-pretty -c -t -l",
    "start:dev:trainee-bc": "nest start trainee-bc --watch | pino-pretty -c -t -l",
    "start:dev:package-bc": "nest start package-bc --watch | pino-pretty -c -t -l",
    "start:dev:appointment-bc": "nest start appointment-bc --watch | pino-pretty -c -t -l",
    "start:dev:all": "concurrently --names \"AUTH,TRAINER,TRAINEE,PACKAGE,APPT\" --prefix-colors \"magenta,blue,green,yellow,cyan\" \"npm:start:dev:auth\" \"npm:start:dev:trainer-bc\" \"npm:start:dev:trainee-bc\" \"npm:start:dev:package-bc\" \"npm:start:dev:appointment-bc\"",
    "start:web": "pnpm --dir apps/web start",
    "build:web": "pnpm --dir apps/web run build",
    "test:web": "pnpm --dir apps/web test",
    "start:prod:auth": "node dist/apps/auth/main",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:auth": "npm run typeorm -- -d libs/database/src/data-source/data-source.auth.ts",
    "typeorm:trainer": "npm run typeorm -- -d libs/database/src/data-source/data-source.trainer.ts",
    "typeorm:trainee": "npm run typeorm -- -d libs/database/src/data-source/data-source.trainee.ts",
    "typeorm:package": "npm run typeorm -- -d libs/database/src/data-source/data-source.package.ts",
    "typeorm:appointment": "npm run typeorm -- -d libs/database/src/data-source/data-source.appointment.ts",
    "migration:run:auth": "npm run typeorm:auth -- migration:run",
    "migration:run:trainer": "npm run typeorm:trainer -- migration:run",
    "migration:run:trainee": "npm run typeorm:trainee -- migration:run",
    "migration:run:package": "npm run typeorm:package -- migration:run",
    "migration:run:appointment": "npm run typeorm:appointment -- migration:run",
    "migration:run:all": "npm run migration:run:auth && npm run migration:run:trainer && npm run migration:run:trainee && npm run migration:run:package && npm run migration:run:appointment",
    "migration:generate:auth": "npm run typeorm:auth -- migration:generate libs/database/src/migrations/fit_binder_auth/$npm_config_name",
    "migration:generate:trainer": "npm run typeorm:trainer -- migration:generate libs/database/src/migrations/fit_binder_trainer/$npm_config_name",
    "migration:generate:trainee": "npm run typeorm:trainee -- migration:generate libs/database/src/migrations/fit_binder_trainee/$npm_config_name",
    "migration:generate:package": "npm run typeorm:package -- migration:generate libs/database/src/migrations/fit_binder_package/$npm_config_name",
    "migration:generate:appointment": "npm run typeorm:appointment -- migration:generate libs/database/src/migrations/fit_binder_appointment/$npm_config_name",
    "migration:revert:auth": "npm run typeorm:auth -- migration:revert",
    "migration:revert:trainer": "npm run typeorm:trainer -- migration:revert",
    "migration:revert:trainee": "npm run typeorm:trainee -- migration:revert",
    "migration:revert:package": "npm run typeorm:package -- migration:revert",
    "migration:revert:appointment": "npm run typeorm:appointment -- migration:revert"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@scalar/nestjs-api-reference": "1.0.15",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dayjs": "^1.11.19",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.26",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/apps/web/"
    ],
    "moduleNameMapper": {
      "^@lib/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@lib/config(|/.*)$": "<rootDir>/libs/config/src/$1",
      "^@lib/database(|/.*)$": "<rootDir>/libs/database/src/$1"
    }
  }
}
